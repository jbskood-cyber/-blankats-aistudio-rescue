# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# NEXT_PUBLIC_APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, Mercado Pago return URLs, and API endpoints.
NEXT_PUBLIC_APP_URL="MY_APP_URL"

# Mercado Pago configuration
MERCADO_PAGO_ACCESS_TOKEN=

# Supabase configuration
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# NEXT_PUBLIC_DEMO_MODE: Enable demo fallback mode (set to "true" for development fallback, "false" or empty for real production flow).
NEXT_PUBLIC_DEMO_MODE=

